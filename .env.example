# --- LLM (required) ---
GROQ_API_KEY=

# --- GitHub (required) ---
GITHUB_TOKEN=
# Optional fallback repo for threads not yet linked via `repo: owner/repo`
GITHUB_REPO=
GITHUB_WEBHOOK_SECRET=

# --- Slack (required) ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# Optional — Socket Mode not used; HTTPS Events API only
SLACK_APP_TOKEN=
# OAuth (optional — use /slack/oauth/install for multi-workspace)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://your-cloud-run-url/slack/oauth/callback

# --- Email / Resend (required) ---
RESEND_API_KEY=
EMAIL_FROM=bot@yourdomain.com

# --- Database ---
DATABASE_URL=sqlite:///./featurebot.db

# --- LLM (required) ---
# Get from https://console.groq.com
GROQ_API_KEY=
# Optional — not used by current code
OPENAI_API_KEY=

# --- GitHub (required) ---
# Classic PAT with repo scope: https://github.com/settings/tokens
GITHUB_TOKEN=
# Optional fallback repo (owner/repo) for chat threads that haven't linked
# their own repo yet. Normally you don't need this: in any Chat thread, send
# "@FeatureBot repo: owner/repo" (or paste a github.com URL) to link that
# thread to a repo — no .env edit or restart needed.
GITHUB_REPO=
# Random secret you choose; must match GitHub webhook secret (openssl rand -hex 32)
GITHUB_WEBHOOK_SECRET=

# --- Google Chat (required) ---
# Download JSON key from GCP → IAM → Service Accounts → Keys
GOOGLE_SERVICE_ACCOUNT_FILE=./service_account.json
# From GCP → Google Chat API → Configuration → Verification token
GOOGLE_CHAT_VERIFICATION_TOKEN=

# --- Email / Resend (required) ---
# https://resend.com — domain must be verified for production sends
RESEND_API_KEY=
EMAIL_FROM=bot@yourdomain.com

# --- Database ---
# Local dev: sqlite file. Production: postgres URL from Neon/Supabase.
# e.g. postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=sqlite:///./featurebot.db

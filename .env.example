# --- LLM ---
GROQ_API_KEY=
# Optional fallback / quality node
OPENAI_API_KEY=

# --- GitHub ---
GITHUB_TOKEN=              # personal access token with repo scope
GITHUB_REPO=yourorg/yourrepo
GITHUB_WEBHOOK_SECRET=     # set when you register the webhook on GitHub

# --- Google Chat ---
# Path to the service account JSON key you download from GCP console
GOOGLE_SERVICE_ACCOUNT_FILE=./service_account.json
# The Chat app's verification token (from Chat API config) - used to validate incoming requests
GOOGLE_CHAT_VERIFICATION_TOKEN=

# --- Email (Resend is simplest to start with) ---
RESEND_API_KEY=
EMAIL_FROM=bot@yourdomain.com

# --- Database ---
# Local dev: sqlite file. Production: postgres URL from Neon/Supabase.
# e.g. postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=sqlite:///./featurebot.db
